<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huuc.dormitory.dao.SysOperLogMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="SysOperLog">
        <id column="log_id" property="logId"/>
        <result column="operator_id" property="operatorId"/>
        <result column="module_name" property="moduleName"/>
        <result column="oper_type" property="operType"/>
        <result column="oper_desc" property="operDesc"/>
        <result column="oper_ip" property="operIp"/>
        <result column="request_param" property="requestParam"/>
        <result column="oper_time" property="operTime"/>
    </resultMap>

    <!-- 插入操作日志 -->
    <insert id="insert" parameterType="SysOperLog" useGeneratedKeys="true" keyProperty="logId">
        INSERT INTO sys_oper_log (operator_id, module_name, oper_type, oper_desc, oper_ip, request_param, oper_time)
        VALUES (#{operatorId}, #{moduleName}, #{operType}, #{operDesc}, #{operIp}, #{requestParam}, #{operTime})
    </insert>

    <!-- 根据操作人ID查询日志列表 -->
    <select id="selectByOperatorId" parameterType="Long" resultMap="BaseResultMap">
        SELECT * FROM sys_oper_log
        WHERE operator_id = #{operatorId}
        ORDER BY oper_time DESC
    </select>

    <!-- 查询日志列表 -->
    <select id="selectList" parameterType="SysOperLog" resultMap="BaseResultMap">
        SELECT * FROM sys_oper_log
        <where>
            <if test="operatorId != null">
                AND operator_id = #{operatorId}
            </if>
            <if test="moduleName != null and moduleName != ''">
                AND module_name = #{moduleName}
            </if>
            <if test="operType != null and operType != ''">
                AND oper_type = #{operType}
            </if>
        </where>
        ORDER BY oper_time DESC
    </select>
</mapper>
