<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huuc.dormitory.dao.SysUserMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="SysUser">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="role_type" property="roleType"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="grade" property="grade"/>
        <result column="major" property="major"/>
        <result column="class_name" property="className"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" parameterType="String" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        WHERE username = #{username} AND is_deleted = 0
    </select>

    <!-- 根据ID查询用户 -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        WHERE user_id = #{userId} AND is_deleted = 0
    </select>

    <!-- 插入用户 -->
    <insert id="insert" parameterType="SysUser" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO sys_user (username, password, real_name, role_type, gender, phone, grade, major, class_name, status)
        VALUES (#{username}, #{password}, #{realName}, #{roleType}, #{gender}, #{phone}, #{grade}, #{major}, #{className}, #{status})
    </insert>

    <!-- 更新用户信息 -->
    <update id="update" parameterType="SysUser">
        UPDATE sys_user
        <set>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="roleType != null">role_type = #{roleType},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="grade != null">grade = #{grade},</if>
            <if test="major != null">major = #{major},</if>
            <if test="className != null">class_name = #{className},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE user_id = #{userId} AND is_deleted = 0
    </update>

    <!-- 更新密码 -->
    <update id="updatePassword">
        UPDATE sys_user
        SET password = #{password}
        WHERE user_id = #{userId} AND is_deleted = 0
    </update>

    <!-- 更新账号状态 -->
    <update id="updateStatus">
        UPDATE sys_user
        SET status = #{status}
        WHERE user_id = #{userId} AND is_deleted = 0
    </update>

    <!-- 查询用户列表 -->
    <select id="selectList" parameterType="SysUser" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        <where>
            is_deleted = 0
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name LIKE CONCAT('%', #{realName}, '%')
            </if>
            <if test="roleType != null">
                AND role_type = #{roleType}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据角色类型查询用户列表 -->
    <select id="selectByRoleType" parameterType="Integer" resultMap="BaseResultMap">
        SELECT * FROM sys_user
        WHERE role_type = #{roleType} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>
</mapper>
