<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huuc.dormitory.dao.DormLateReturnMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="DormLateReturn">
        <id column="record_id" property="recordId"/>
        <result column="student_id" property="studentId"/>
        <result column="building_id" property="buildingId"/>
        <result column="late_time" property="lateTime"/>
        <result column="late_reason" property="lateReason"/>
        <result column="registrar_id" property="registrarId"/>
        <result column="record_time" property="recordTime"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据ID查询晚归记录 -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT * FROM dorm_late_return
        WHERE record_id = #{recordId}
    </select>

    <!-- 根据学生ID查询晚归记录列表 -->
    <select id="selectByStudentId" parameterType="Long" resultMap="BaseResultMap">
        SELECT * FROM dorm_late_return
        WHERE student_id = #{studentId}
        ORDER BY late_time DESC
    </select>

    <!-- 查询晚归记录列表 -->
    <select id="selectList" parameterType="DormLateReturn" resultMap="BaseResultMap">
        SELECT * FROM dorm_late_return
        <where>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="buildingId != null">
                AND building_id = #{buildingId}
            </if>
        </where>
        ORDER BY late_time DESC
    </select>

    <!-- 根据楼栋ID查询晚归记录列表 -->
    <select id="selectByBuildingId" parameterType="Long" resultMap="BaseResultMap">
        SELECT * FROM dorm_late_return
        WHERE building_id = #{buildingId}
        ORDER BY late_time DESC
    </select>

    <!-- 插入晚归记录 -->
    <insert id="insert" parameterType="DormLateReturn" useGeneratedKeys="true" keyProperty="recordId">
        INSERT INTO dorm_late_return (student_id, building_id, late_time, late_reason, registrar_id, record_time)
        VALUES (#{studentId}, #{buildingId}, #{lateTime}, #{lateReason}, #{registrarId}, #{recordTime})
    </insert>

    <!-- 按楼栋月度统计晚归人次 -->
    <select id="selectMonthlyStats" resultType="com.huuc.dormitory.vo.LateReturnStatVO">
        SELECT
            db.building_id AS buildingId,
            db.building_name AS buildingName,
            COUNT(*) AS count
        FROM dorm_late_return dlr
        LEFT JOIN dorm_building db ON dlr.building_id = db.building_id
        <where>
            DATE_FORMAT(dlr.late_time, '%Y-%m') = #{yearMonth}
            <if test="managerId != null">
                AND db.manager_id = #{managerId}
            </if>
        </where>
        GROUP BY db.building_id, db.building_name
        ORDER BY db.building_name
    </select>
</mapper>
